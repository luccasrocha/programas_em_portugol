// sempre tem que ter alguma palavra para começar
programa
{
    funcao inicio()
    {
        // chamamos a função que dara inicio a tudo
        cadeia nome = 0 // chamamos a função cadeira
        escreva("Qual e seu nome? ") // pedimos o nome
                leia(nome) // vai ler a função nome
        escreva("Seja bem vindo, ", nome) // aq chamamos o escreva colocamos a mensagem dps uma , e a função que queremos mostrar
    }
}
